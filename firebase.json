{
  "functions": [
    {
      "codebase": "default",
      "source": ".output/server",
      "runtime": "nodejs22"
    }
  ],
  "hosting": {
    "public": ".output/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "function": "server",
        "region": "us-central1"
      }
    ]
  }
}